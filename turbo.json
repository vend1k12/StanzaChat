{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "CI",
    "DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "ENCRYPTION_MASTER_KEY",
    "E2E_MOCK_PROVIDER",
    "NODE_ENV",
    "PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": []
    },
    "test:integration": {
      "dependsOn": []
    },
    "test:e2e": {
      "dependsOn": ["build", "^build"],
      "cache": false
    },
    "db:generate": {
      "dependsOn": []
    },
    "db:migrate": {
      "dependsOn": ["^db:generate"]
    },
    "db:push": {
      "dependsOn": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}

{
  "name": "@repo/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint . --max-warnings=0",
    "test": "bun test test/slug.test.ts",
    "test:integration": "bun test test/setup.integration.test.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema.ts",
    "./setup": "./src/setup.ts",
    "./slug": "./src/slug.ts",
    "./admin": "./src/admin.ts"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testcontainers/postgresql": "^11.8.1",
    "@types/bun": "^1.3.2",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.1",
    "testcontainers": "^11.8.1",
    "typescript": "5.9.2"
  }

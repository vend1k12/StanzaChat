{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":gitSignOff",
    ":semanticCommitScope(repo)"
  ],
  "timezone": "Etc/UTC",
  "schedule": ["before 5am on the first day of the month"],
  "prConcurrentLimit": 2,
  "prHourlyLimit": 0,
  "branchConcurrentLimit": 2,
  "minimumReleaseAge": "7 days",
  "rangeStrategy": "bump",
  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": ["dependencies", "security"],
    "semanticCommitType": "fix",
    "semanticCommitScope": "repo",
    "schedule": ["at any time"],
    "minimumReleaseAge": "0 days",
    "dependencyDashboardApproval": false
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on the first day of the month"],
    "commitMessageAction": "refresh"
  },
  "packageRules": [
    {
      "description": "Node runtime (engines.node in package.json, .nvmrc, tool-versions, Dockerfile bases) is managed by hand alongside SPEC updates.",
      "matchDepNames": ["node"],
      "matchManagers": ["nvm", "npm", "dockerfile", "asdf"],
      "enabled": false
    },
    {
      "description": "Group all non-major npm updates into a single monthly PR. No approval; only rate-limited by schedule + concurrency.",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "groupName": "npm minor and patch",
      "semanticCommitType": "chore",
      "semanticCommitScope": "repo",
      "labels": ["dependencies", "npm"]
    },
    {
      "description": "npm majors surface via the dependency dashboard and must be approved by the maintainer before Renovate opens a PR.",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "semanticCommitType": "chore",
      "semanticCommitScope": "repo",
      "labels": ["dependencies", "npm", "major"]
    },
    {
      "description": "Group all non-major GitHub Actions updates into a single monthly PR (minor + patch + digest + pin refresh).",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "groupName": "github-actions minor and patch",
      "semanticCommitType": "ci",
      "semanticCommitScope": "",
      "labels": ["dependencies", "github-actions"]
    },
    {
      "description": "GitHub Actions majors require maintainer approval on the dependency dashboard.",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "semanticCommitType": "ci",
      "semanticCommitScope": "",
      "labels": ["dependencies", "github-actions", "major"]
    }
  ],
  "labels": ["dependencies"]
}

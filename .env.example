# StanzaChat — environment variables (SPEC §8)
#
# Copy to `.env` and fill in. All variables marked Required must be
# present at boot; the app refuses to start in production with missing
# or default-looking secrets (guardrails #4).

# ── Required ─────────────────────────────────────────────────────────

# PostgreSQL DSN. Use pgvector image for forward-compat with v0.2 RAG.
DATABASE_URL=postgres://stanzachat:stanzachat@localhost:5432/stanzachat

# Better-Auth session secret. ≥ 32 random bytes.
# Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=

# Public-facing app URL (no trailing slash).
BETTER_AUTH_URL=http://localhost:3000

# AES-256-GCM master key for provider API key encryption (SPEC §7).
# Must be base64-encoded 32 bytes (256 bits).
# Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=

# ── Optional ─────────────────────────────────────────────────────────

# Port for the Next.js server. Default: 3000.
# PORT=3000

# Node environment. One of: development, test, production.
# NODE_ENV=development

# Swap the AI provider for a server-side mock LanguageModel that emits
# two `<artifact>` blocks in one message (v1 + v2). Used by Playwright
# E2E to get deterministic artifact versions without provider keys.
# Rejected by the env schema when NODE_ENV=production (guardrails #4).
# E2E_MOCK_PROVIDER=1